# ─── Backend API (legacy / TuresColombia) ─────────────────
NEXT_PUBLIC_API_URL=https://your-api.example.com/api

# ─── Supabase (auth + datos) ──────────────────────────────
# El anon key es publico por diseño en Supabase; aun asi no lo
# committeamos para evitar que mañana entre por error un service-role.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Wompi (pagos, sandbox por defecto) ───────────────────
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=
NEXT_PUBLIC_WOMPI_ENV=sandbox
